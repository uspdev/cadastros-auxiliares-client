# Habilita integração de mensagens
CADASTROS_AUXILIARES_MENSAGENS_INTEGRACAO=false

# Endpoint GET /api/mensagens do cadastros-auxiliares
CADASTROS_AUXILIARES_MENSAGENS_ENDPOINT_URL=https://cadastros-auxiliares.seu-dominio/api/mensagens

# Senha obrigatória para chamadas ao endpoint de mensagens
CADASTROS_AUXILIARES_PASSWORD=

# Nome do sistema consumidor (ex.: ponto, pessoas, chamados)
CADASTROS_AUXILIARES_SISTEMA_NAME=

# Limite padrão de mensagens
CADASTROS_AUXILIARES_MENSAGENS_LIMITE=5

# Tempo para auto-dismiss das mensagens no tema (0 para desabilitar)
CADASTROS_AUXILIARES_MENSAGENS_TIMEOUT=0

# Intervalo de atualização das mensagens no tema
CADASTROS_AUXILIARES_MENSAGENS_REFRESH=30
